{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "linkverse-route": {
        "ClusterId": "linkverse-cluster",
        "Match": {
          "Path": "linkverse/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "linkverse-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5147"
          },
          "destination2": {
            "Address": "https://localhost:7174"
          },
          "destination3": {
            "Address": "https://localhost:7175"
          }
        }
      }
    }
  }
}
